---
import "../styles/globals.css";
import "devicon/devicon.min.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Toaster from "../components/toaster.tsx";
import { themeInitScript } from "../lib/theme-init";

interface Props {
  /** Page title — gets the " | Seanne Cañete" suffix unless `rawTitle` is set. */
  title?: string;
  /** Use the title verbatim, no suffix. Defaults to false. */
  rawTitle?: boolean;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** Explicit OG title override; defaults to `${title} | Seanne Cañete`. */
  ogTitle?: string;
  /** OG type (defaults to "website"). */
  ogType?: "website" | "article" | "profile";
  /** Extra <meta name="keywords"> (comma-joined). */
  keywords?: string[];
}

const SITE_URL =
  import.meta.env.PUBLIC_SITE_URL ?? "https://seanneskie.github.io";
const BASE_PATH = import.meta.env.BASE_URL.replace(/\/$/, "");

const {
  title = "Seanne Cañete | Full-Stack Engineer",
  rawTitle = false,
  description = "Seanne Cañete is a full-stack engineer and Information Technology graduate from Mindanao State University - General Santos City. Explore projects, experience, and engineering work.",
  canonical = "/",
  ogImage = "/static/bg_2.jpg",
  ogTitle,
  ogType = "website",
  keywords,
} = Astro.props;

const finalTitle = rawTitle ? title : `${title} | Seanne Cañete`;
const finalOgTitle = ogTitle ?? finalTitle;

const joinBase = (path: string): string => {
  if (/^https?:\/\//.test(path)) return path;
  const normalized = path.startsWith("/") ? path : `/${path}`;
  return `${SITE_URL}${BASE_PATH}${normalized}`;
};

const absoluteCanonical = joinBase(canonical);
const absoluteOgImage = joinBase(ogImage);

// Basepath-prefixed favicon URLs (relative to site root, not the absolute SITE_URL).
const faviconIco = `${BASE_PATH}/static/favicon.ico`;
const favicon16 = `${BASE_PATH}/static/favicon-16x16.png`;
const favicon32 = `${BASE_PATH}/static/favicon-32x32.png`;
const appleTouchIcon = `${BASE_PATH}/static/apple-touch-icon.png`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Seanne Cañete",
  alternateName: "Seanne Canete",
  url: `${SITE_URL}${BASE_PATH}`,
  jobTitle: "Full-Stack Engineer",
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Mindanao State University - General Santos",
  },
  knowsAbout: [
    "Full-Stack Development",
    "React",
    "Next.js",
    "TypeScript",
    "Python",
    "Data Analysis",
  ],
  sameAs: [
    "https://github.com/Seanneskie",
    "https://www.linkedin.com/in/seanne-ca%C3%B1ete-8b09322a1/",
    "https://x.com/Seanneskie",
  ],
};
---

<!doctype html>
<html lang="en" suppressHydrationWarning>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* FOUC-safe theme init — must run before paint */}
    <script is:inline set:html={themeInitScript} />
    <title>{finalTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteCanonical} />

    <link rel="icon" href={faviconIco} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Seanne Cañete | Portfolio" />
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@Seanneskie" />
    <meta name="twitter:title" content={finalOgTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="antialiased min-h-screen bg-white text-black dark:bg-gray-900 dark:text-white font-sans">
    <Toaster client:idle />
    <Header />
    <slot />
    <Footer />
  </body>
</html>
