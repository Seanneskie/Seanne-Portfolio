---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectsPageContent from "../../../components/projects/projects-page-content.tsx";

const entries = await getCollection("projects");
const data = entries.map((e) => e.data);
---

<BaseLayout
  title="Projects"
  description="Browse software engineering projects by Seanne Cañete, a full-stack engineer focused on web apps, data analysis, and automation tools."
  canonical="/projects/"
>
  <ProjectsPageContent client:load data={data} />
</BaseLayout>
