---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TravelMap from "../../../../components/travels/TravelMap.tsx";
import TravelGallery from "../../../../components/travels/TravelGallery.tsx";
import { withBase } from "../../../lib/with-base";
import { travelOgImageFrom } from "../../../lib/travel-og";

export async function getStaticPaths() {
  const trips = await getCollection("trips");
  const travels = await getCollection("travels");
  return trips.map((trip) => ({
    params: { slug: trip.id.replace(/\.md$/, "") },
    props: { trip, travels, allTrips: trips },
  }));
}

const { trip, travels, allTrips } = Astro.props;
const { Content } = await render(trip);

const slug = trip.id.replace(/\.md$/, "");
const pageTitle = `${trip.data.title} | Travels`;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const fmtDateRange = (start: Date, end?: Date): string => {
  if (!end) return fmtDate(start);
  const sameMonth = start.getFullYear() === end.getFullYear() && start.getMonth() === end.getMonth();
  if (sameMonth) {
    const startStr = start.toLocaleDateString("en-US", { month: "long", day: "numeric" });
    return `${startStr}–${end.getDate()}, ${end.getFullYear()}`;
  }
  return `${fmtDate(start)} – ${fmtDate(end)}`;
};

// Stops in itinerary order. `trip.data.stops` is the source of truth; any
// travel entry with `trip: <slug>` that isn't in `stops` is appended at the
// end (date-sorted) so authoring a stop without updating the trip's order
// list doesn't make it vanish from the detail page.
const tripTravels = travels.filter((t) => t.data.trip === slug);
const stopRank = new Map(trip.data.stops.map((s, i) => [s, i]));
const orderedStops = [...tripTravels].sort((a, b) => {
  const sa = a.id.replace(/\.md$/, "");
  const sb = b.id.replace(/\.md$/, "");
  const ra = stopRank.has(sa) ? stopRank.get(sa)! : Number.MAX_SAFE_INTEGER;
  const rb = stopRank.has(sb) ? stopRank.get(sb)! : Number.MAX_SAFE_INTEGER;
  if (ra !== rb) return ra - rb;
  return a.data.date.getTime() - b.data.date.getTime();
});

// TravelMap input — keep only stops with coords. The map renders the trip
// polyline because `tripGroups` includes this trip; no need to fake an
// activeSlug from the page since the user navigates within the page itself.
const mapTrips = orderedStops
  .filter((t) => t.data.coords)
  .map((t) => ({
    slug: t.id.replace(/\.md$/, ""),
    title: t.data.title,
    date: t.data.date.toISOString(),
    endDate: t.data.endDate?.toISOString(),
    location: t.data.location,
    city: t.data.city,
    country: t.data.country,
    coords: t.data.coords,
    cover: t.data.cover,
    excerpt: t.data.excerpt,
    tags: t.data.tags,
    trip: t.data.trip,
  }));

const mapTripGroups = [
  {
    slug,
    title: trip.data.title,
    startDate: trip.data.startDate.toISOString(),
    endDate: trip.data.endDate?.toISOString(),
    location: trip.data.location,
    summary: trip.data.summary,
    stops: trip.data.stops,
  },
];

// Hero / OG image: the trip's explicit cover, else the first stop (in
// itinerary order) that yields a cover or gallery image, else the site
// default.
const ogImage =
  trip.data.cover ?? travelOgImageFrom(orderedStops.map((s) => s.data));

// Related trips — other trips ranked by shared tags first, then by recency.
// Falls back to plain recency when no tags overlap so the section is never
// empty as long as another trip exists.
const tripTags = new Set(trip.data.tags);
const relatedTrips = allTrips
  .filter((t) => t.id !== trip.id && !t.data.draft)
  .map((t) => {
    const shared = t.data.tags.filter((tag) => tripTags.has(tag)).length;
    return { trip: t, shared };
  })
  .sort((a, b) => {
    if (b.shared !== a.shared) return b.shared - a.shared;
    return b.trip.data.startDate.getTime() - a.trip.data.startDate.getTime();
  })
  .slice(0, 3)
  .map(({ trip: t }) => {
    const tSlug = t.id.replace(/\.md$/, "");
    const tStops = travels.filter((v) => v.data.trip === tSlug);
    return {
      slug: tSlug,
      title: t.data.title,
      startDate: t.data.startDate,
      endDate: t.data.endDate,
      location: t.data.location,
      stopCount: tStops.length,
      image:
        t.data.cover ??
        travelOgImageFrom(tStops.map((v) => v.data)),
    };
  });

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  name: trip.data.title,
  description: trip.data.summary,
  itinerary: orderedStops.map((s, i) => ({
    "@type": "Place",
    position: i + 1,
    name: s.data.title,
    address: s.data.location,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={trip.data.summary ?? trip.data.title}
  canonical={`/travels/trip/${slug}/`}
  ogType="article"
  ogImage={ogImage}
>
  <main class="container mx-auto max-w-4xl px-4 py-12">
    <a
      href={withBase("/travels/")}
      class="inline-flex items-center gap-1 text-sm font-medium text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100"
    >
      ← All travels
    </a>

    <header class="mt-6 mb-8">
      <p class="text-xs font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">
        Trip · {orderedStops.length} stop{orderedStops.length === 1 ? "" : "s"}
      </p>
      <h1 class="mt-1 text-3xl font-semibold text-black dark:text-white sm:text-4xl">
        {trip.data.title}
      </h1>
      <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-gray-600 dark:text-gray-300">
        {trip.data.author && (
          <span class="font-medium text-gray-800 dark:text-gray-100">By {trip.data.author}</span>
        )}
        <time>{fmtDateRange(trip.data.startDate, trip.data.endDate)}</time>
        {trip.data.readTime && <span>· {trip.data.readTime}</span>}
        <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-200">
          {trip.data.location}
        </span>
      </div>
      {trip.data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {trip.data.tags.map((tag) => (
            <span class="rounded-full bg-teal-500/10 px-2.5 py-0.5 text-[11px] font-medium text-teal-800 dark:bg-teal-400/10 dark:text-teal-200">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {ogImage && (
      <img
        src={withBase(ogImage)}
        alt=""
        class="mb-10 aspect-video w-full rounded-xl object-cover"
      />
    )}

    {mapTrips.length > 0 && (
      <div class="mb-10">
        <TravelMap
          client:only="react"
          trips={mapTrips}
          tripGroups={mapTripGroups}
          activeSlug={null}
          onSelect={() => undefined}
          alwaysShowTrip={slug}
        />
      </div>
    )}

    {trip.data.summary && (
      <article
        class="trip-article prose prose-teal mb-12 max-w-none dark:prose-invert prose-headings:font-semibold prose-p:leading-relaxed prose-img:rounded-xl"
      >
        <Content />
      </article>
    )}

    {(trip.data.gallery.length > 0 || trip.data.videos.length > 0) && (
      <section class="mb-12">
        <h2 class="mb-4 text-xl font-semibold text-black dark:text-white">Gallery</h2>
        <TravelGallery
          client:visible
          gallery={trip.data.gallery}
          videos={trip.data.videos}
        />
      </section>
    )}

    <section>
      <h2 class="mb-4 text-xl font-semibold text-black dark:text-white">Itinerary</h2>
      <ol class="space-y-3">
        {orderedStops.map((stop, i) => {
          const stopSlug = stop.id.replace(/\.md$/, "");
          return (
            <li>
              <a
                href={withBase(`/travels/${stopSlug}/`)}
                class="group flex gap-4 overflow-hidden rounded-lg border border-gray-200 bg-white p-3 transition hover:border-teal-500/50 dark:border-gray-800 dark:bg-gray-900/40 dark:hover:border-teal-400/50"
              >
                <div class="relative shrink-0">
                  {stop.data.cover ? (
                    <img
                      src={withBase(stop.data.cover)}
                      alt=""
                      class="h-24 w-24 rounded-md object-cover sm:h-28 sm:w-40"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-24 w-24 items-center justify-center rounded-md bg-teal-500/10 text-2xl sm:h-28 sm:w-40">
                      <span aria-hidden="true">🗺️</span>
                    </div>
                  )}
                  <span
                    aria-hidden="true"
                    class="absolute -left-1 -top-1 flex h-6 w-6 items-center justify-center rounded-full bg-teal-500 text-xs font-semibold text-white ring-2 ring-white dark:ring-gray-900"
                  >
                    {i + 1}
                  </span>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center justify-between gap-2 text-xs text-gray-500 dark:text-gray-400">
                    <time>{fmtDate(stop.data.date)}</time>
                    <span class="truncate">{stop.data.location}</span>
                  </div>
                  <h3 class="mt-0.5 text-base font-semibold text-black group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">
                    {stop.data.title}
                  </h3>
                  {stop.data.excerpt && (
                    <p class="mt-0.5 line-clamp-2 text-sm text-gray-600 dark:text-gray-300">
                      {stop.data.excerpt}
                    </p>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    </section>

    {relatedTrips.length > 0 && (
      <section class="mt-12 border-t border-gray-200 pt-8 dark:border-gray-800">
        <h2 class="mb-4 text-xl font-semibold text-black dark:text-white">More trips</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {relatedTrips.map((rt) => (
            <a
              href={withBase(`/travels/trip/${rt.slug}/`)}
              class="group overflow-hidden rounded-lg border border-gray-200 bg-white transition hover:border-teal-500/50 dark:border-gray-800 dark:bg-gray-900/40 dark:hover:border-teal-400/50"
            >
              <img
                src={withBase(rt.image)}
                alt=""
                class="aspect-video w-full object-cover transition group-hover:opacity-90"
                loading="lazy"
              />
              <div class="p-3">
                <h3 class="text-sm font-semibold text-black group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">
                  {rt.title}
                </h3>
                <div class="mt-1 flex items-center justify-between gap-2 text-xs text-gray-500 dark:text-gray-400">
                  <time>{fmtDateRange(rt.startDate, rt.endDate)}</time>
                  <span>{rt.stopCount} stop{rt.stopCount === 1 ? "" : "s"}</span>
                </div>
                <p class="mt-0.5 truncate text-xs text-gray-500 dark:text-gray-400">{rt.location}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </main>
</BaseLayout>

<style>
  /* Blog-style drop cap on the first paragraph of the trip write-up. */
  .trip-article > :global(p:first-of-type::first-letter) {
    float: left;
    margin-right: 0.5rem;
    font-size: 3.25rem;
    font-weight: 600;
    line-height: 0.85;
    color: var(--tw-prose-headings, #0f766e);
  }
</style>
