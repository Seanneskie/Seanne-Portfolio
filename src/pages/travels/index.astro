---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TravelsView from "../../../components/travels/TravelsView.tsx";

const isProd = import.meta.env.PROD;

const trips = (await getCollection("travels"))
  .filter((e) => isProd ? !e.data.draft : true)
  .map((e) => ({
    slug: e.id.replace(/\.md$/, ""),
    title: e.data.title,
    date: e.data.date.toISOString(),
    endDate: e.data.endDate?.toISOString(),
    location: e.data.location,
    city: e.data.city,
    country: e.data.country,
    coords: e.data.coords,
    cover: e.data.cover,
    excerpt: e.data.excerpt,
    tags: e.data.tags,
    trip: e.data.trip,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const tripGroups = (await getCollection("trips"))
  .filter((e) => isProd ? !e.data.draft : true)
  .map((e) => ({
    slug: e.id.replace(/\.md$/, ""),
    title: e.data.title,
    startDate: e.data.startDate.toISOString(),
    endDate: e.data.endDate?.toISOString(),
    location: e.data.location,
    summary: e.data.summary,
    stops: e.data.stops,
  }));
---

<BaseLayout
  title="Travels"
  description="Trips, photos, and notes from the road — Seanne Cañete's travel log."
  canonical="/travels/"
>
  <main class="container mx-auto max-w-6xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold text-black dark:text-white sm:text-4xl">Travels</h1>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
        Pins on a map, photos along the way. Hover a card or pin to sync the two.
      </p>
    </header>

    {/* Leaflet touches `window` at import time, so the parent island must be
       client:only — server rendering it would crash the build. */}
    <TravelsView client:only="react" trips={trips} tripGroups={tripGroups} />
  </main>
</BaseLayout>
