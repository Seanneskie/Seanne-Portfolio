---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TravelMap from "../../../components/travels/TravelMap.tsx";
import TravelGallery from "../../../components/travels/TravelGallery.tsx";
import { withBase } from "../../lib/with-base";
import { travelOgImage } from "../../lib/travel-og";

export async function getStaticPaths() {
  const entries = (await getCollection("travels")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  const trips = await getCollection("trips");
  return entries.map((entry, index) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: {
      entry,
      prev: entries[index - 1] ?? null,
      next: entries[index + 1] ?? null,
      parentTrip:
        trips.find((t) => t.id.replace(/\.md$/, "") === entry.data.trip) ?? null,
    },
  }));
}

const { entry, prev, next, parentTrip } = Astro.props;
const { Content } = await render(entry);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const slug = entry.id.replace(/\.md$/, "");
const pageTitle = `${entry.data.title} | Travels`;
const ogImage = travelOgImage(entry.data);

// Single-pin map data — re-uses the same TravelMap island as the listing view,
// driven by a one-entry trips array so the pin centers automatically.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.excerpt,
  datePublished: entry.data.date.toISOString(),
  author: { "@type": "Person", name: "Seanne Cañete" },
  keywords: entry.data.tags.join(", "),
  image: ogImage,
  contentLocation: { "@type": "Place", name: entry.data.location },
  mainEntityOfPage: `/travels/${slug}/`,
};

const singleTrip = entry.data.coords
  ? [
      {
        slug,
        title: entry.data.title,
        date: entry.data.date.toISOString(),
        location: entry.data.location,
        coords: entry.data.coords,
        excerpt: entry.data.excerpt,
        tags: entry.data.tags,
      },
    ]
  : [];
---

<BaseLayout
  title={pageTitle}
  description={entry.data.excerpt ?? entry.data.title}
  canonical={`/travels/${slug}/`}
  ogType="article"
  ogImage={ogImage}
  keywords={entry.data.tags}
>
  <main class="container mx-auto max-w-4xl px-4 py-12">
    <a
      href={withBase("/travels/")}
      class="inline-flex items-center gap-1 text-sm font-medium text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100"
    >
      ← All travels
    </a>

    <header class="mt-6 mb-6">
      {parentTrip && (
        <a
          href={withBase(`/travels/trip/${parentTrip.id.replace(/\.md$/, "")}/`)}
          class="inline-flex items-center gap-1 rounded-full bg-teal-500/10 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-teal-800 hover:bg-teal-500/20 dark:bg-teal-400/10 dark:text-teal-200 dark:hover:bg-teal-400/20"
        >
          Part of: {parentTrip.data.title} →
        </a>
      )}
      <h1 class={`text-3xl font-semibold text-black dark:text-white sm:text-4xl ${parentTrip ? "mt-2" : ""}`}>
        {entry.data.title}
      </h1>
      <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-gray-600 dark:text-gray-300">
        <time>
          {fmtDate(entry.data.date)}
          {entry.data.endDate && ` – ${fmtDate(entry.data.endDate)}`}
        </time>
        <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-200">
          {entry.data.location}
        </span>
      </div>
    </header>

    {entry.data.cover && (
      <img
        src={withBase(entry.data.cover)}
        alt=""
        class="mb-8 aspect-[16/9] w-full rounded-lg object-cover"
      />
    )}

    {singleTrip.length > 0 && (
      <div class="mb-10">
        <TravelMap
          client:only="react"
          trips={singleTrip}
          activeSlug={slug}
          onSelect={() => undefined}
        />
      </div>
    )}

    <article class="prose prose-teal max-w-none dark:prose-invert">
      <Content />
    </article>

    {(entry.data.gallery.length > 0 || entry.data.videos.length > 0) && (
      <section class="mt-12">
        <h2 class="mb-4 text-xl font-semibold text-black dark:text-white">Gallery</h2>
        <TravelGallery
          client:visible
          gallery={entry.data.gallery}
          videos={entry.data.videos}
        />
      </section>
    )}

    {(prev || next) && (
      <nav class="mt-12 grid gap-3 border-t border-gray-200 pt-8 dark:border-gray-800 sm:grid-cols-2" aria-label="Travel navigation">
        {prev ? (
          <a
            href={withBase(`/travels/${prev.id.replace(/\.md$/, "")}/`)}
            class="group rounded-lg border border-gray-200 p-4 transition hover:border-teal-500/50 dark:border-gray-800 dark:hover:border-teal-400/50"
          >
            <p class="text-xs text-gray-500 dark:text-gray-400">Newer trip</p>
            <p class="mt-1 text-sm font-medium text-black group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">
              ← {prev.data.title}
            </p>
          </a>
        ) : <span />}
        {next ? (
          <a
            href={withBase(`/travels/${next.id.replace(/\.md$/, "")}/`)}
            class="group rounded-lg border border-gray-200 p-4 text-right transition hover:border-teal-500/50 dark:border-gray-800 dark:hover:border-teal-400/50"
          >
            <p class="text-xs text-gray-500 dark:text-gray-400">Older trip</p>
            <p class="mt-1 text-sm font-medium text-black group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">
              {next.data.title} →
            </p>
          </a>
        ) : <span />}
      </nav>
    )}

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </main>
</BaseLayout>
