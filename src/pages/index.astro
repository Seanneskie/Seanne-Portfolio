  description="Phase 3 placeholder: shared layout, theme toggle, header, and footer wired up."
>
  <main class="container mx-auto max-w-3xl px-4 py-24">
    <h1 class="text-4xl font-bold tracking-tight">Phase 3 chrome wired</h1>
    <p class="mt-4 text-gray-600 dark:text-gray-300">
      Header, mobile nav island, theme toggle, and footer are all rendered by
      <code>BaseLayout.astro</code>. Real page content lands in Phase 4.
    </p>
  </main>
</BaseLayout>
