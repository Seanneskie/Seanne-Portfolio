---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Astro OK — Seanne Portfolio"
  description="Phase 1 scaffold placeholder for the Astro migration."
>
  <main class="container mx-auto max-w-3xl px-4 py-24">
    <h1 class="text-4xl font-bold tracking-tight">Astro OK</h1>
    <p class="mt-4 text-gray-600 dark:text-gray-300">
      Phase 1 of the Astro migration is wired up. The Next.js build still
      owns production — see
      <a href="../docs/astro-migration.md" class="text-teal-700 underline dark:text-teal-300">
        docs/astro-migration.md
      </a>
      for the rollout plan.
    </p>
  </main>
</BaseLayout>
