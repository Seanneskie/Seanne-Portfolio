---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogList from "../../../components/blogs/BlogList.tsx";

const isProd = import.meta.env.PROD;

const native = (await getCollection("blogs"))
  .filter((e) => isProd ? !e.data.draft : true)
  .map((e) => ({
    kind: "native" as const,
    slug: e.id.replace(/\.md$/, ""),
    title: e.data.title,
    date: e.data.date.toISOString(),
    description: e.data.description,
    tags: e.data.tags,
  }));

const external = (await getCollection("blog-posts")).map((e) => ({
  kind: "external" as const,
  slug: e.id,
  title: e.data.title,
  date: new Date(e.data.date).toISOString(),
  description: e.data.description,
  url: e.data.url,
  tags: [] as string[],
}));

const posts = [...native, ...external].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---

<BaseLayout
  title="Blogs"
  description="Long-form writing by Seanne Cañete — build notes, project retrospectives, and engineering essays."
  canonical="/blogs/"
>
  <main class="container mx-auto max-w-4xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold text-black dark:text-white sm:text-4xl">Blogs</h1>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
        Notes on engineering, projects, and the occasional rabbit hole.
      </p>
    </header>

    <BlogList client:load posts={posts} />
  </main>
</BaseLayout>
