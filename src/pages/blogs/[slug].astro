---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/with-base";

export async function getStaticPaths() {
  const entries = (await getCollection("blogs")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return entries.map((entry, index) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: {
      entry,
      // newer = previous in chronological-desc; older = next
      prev: entries[index - 1] ?? null,
      next: entries[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const pageTitle = `${entry.data.title} | Blog`;

// ~200 wpm is a reasonable midpoint for English long-form. body is a string
// (the raw Markdown source) when the glob loader is used.
const wordCount = (entry.body ?? "").split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const slug = entry.id.replace(/\.md$/, "");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  author: { "@type": "Person", name: "Seanne Cañete" },
  keywords: entry.data.tags.join(", "),
  image: entry.data.cover,
  mainEntityOfPage: `/blogs/${slug}/`,
};
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description ?? entry.data.title}
  canonical={`/blogs/${entry.id.replace(/\.md$/, "")}/`}
  ogType="article"
  ogImage={entry.data.cover ?? "/static/bg_2.jpg"}
  keywords={entry.data.tags}
>
  <main class="container mx-auto max-w-3xl px-4 py-12">
    <a
      href={withBase("/blogs/")}
      class="inline-flex items-center gap-1 text-sm font-medium text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100"
    >
      ← All posts
    </a>

    <header class="mt-6 mb-8">
      <h1 class="text-3xl font-semibold text-black dark:text-white sm:text-4xl">
        {entry.data.title}
      </h1>
      <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-gray-600 dark:text-gray-300">
        <time>{fmtDate(entry.data.date)}</time>
        <span aria-hidden="true">•</span>
        <span>{readingMinutes} min read</span>
        {entry.data.tags.length > 0 && (
          <ul class="flex flex-wrap gap-1.5">
            {entry.data.tags.map((tag) => (
              <li class="rounded-full bg-teal-500/10 px-2 py-0.5 text-xs font-medium text-teal-700 dark:bg-teal-400/10 dark:text-teal-300">
                #{tag}
              </li>
            ))}
          </ul>
        )}
      </div>
    </header>

    {entry.data.cover && (
      <img
        src={withBase(entry.data.cover)}
        alt=""
        class="mb-8 aspect-[16/9] w-full rounded-lg object-cover"
      />
    )}

    <article class="prose prose-teal max-w-none dark:prose-invert">
      <Content />
    </article>

    {(prev || next) && (
      <nav class="mt-12 grid gap-3 border-t border-gray-200 pt-8 dark:border-gray-800 sm:grid-cols-2" aria-label="Post navigation">
        {prev ? (
          <a
            href={withBase(`/blogs/${prev.id.replace(/\.md$/, "")}/`)}
            class="group rounded-lg border border-gray-200 p-4 transition hover:border-teal-500/50 dark:border-gray-800 dark:hover:border-teal-400/50"
          >
            <p class="text-xs text-gray-500 dark:text-gray-400">Newer post</p>
            <p class="mt-1 text-sm font-medium text-black group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">
              ← {prev.data.title}
            </p>
          </a>
        ) : <span />}
        {next ? (
          <a
            href={withBase(`/blogs/${next.id.replace(/\.md$/, "")}/`)}
            class="group rounded-lg border border-gray-200 p-4 text-right transition hover:border-teal-500/50 dark:border-gray-800 dark:hover:border-teal-400/50"
          >
            <p class="text-xs text-gray-500 dark:text-gray-400">Older post</p>
            <p class="mt-1 text-sm font-medium text-black group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">
              {next.data.title} →
            </p>
          </a>
        ) : <span />}
      </nav>
    )}

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </main>
</BaseLayout>

<style is:global>
  .prose {
    color: inherit;
  }
  .prose h2,
  .prose h3,
  .prose h4 {
    color: inherit;
    font-weight: 600;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
  }
  .prose h2 { font-size: 1.5rem; }
  .prose h3 { font-size: 1.25rem; }
  .prose p,
  .prose ul,
  .prose ol {
    line-height: 1.7;
    margin-bottom: 1em;
  }
  .prose a { color: rgb(15 118 110); text-decoration: underline; }
  :global(.dark) .prose a { color: rgb(94 234 212); }
  .prose code {
    background: rgba(20, 184, 166, 0.1);
    padding: 0.1em 0.3em;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .prose pre {
    background: #0b1220;
    color: #e2e8f0;
    padding: 1em;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.9em;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
  }
  .prose ul { list-style: disc; padding-left: 1.25rem; }
  .prose ol { list-style: decimal; padding-left: 1.25rem; }
  .prose blockquote {
    border-left: 4px solid rgba(20, 184, 166, 0.4);
    padding-left: 1rem;
    color: rgb(75 85 99);
    font-style: italic;
  }
  :global(.dark) .prose blockquote { color: rgb(156 163 175); }
</style>
